# ══════════════════════════════════════════════════════════════════════
#  PsychroScan .gitignore
#  Rule: code + example config = public. Everything else = private.
# ══════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── DATA (large files, reproducible from scripts) ─────────────────────
data/raw/
data/processed/
data/reference_panel/
data/new_genomes/
# Keep data/Done/ excluded too
data/Done/

# ── PRIVATE CONFIG (full taxon list = IP) ─────────────────────────────
# taxa_list_example.json IS tracked — reviewers use it to reproduce
config/taxa_list.json

# ── TRAINED MODEL (commercial asset) ──────────────────────────────────
results/models/

# ── UNPUBLISHED RESULTS (embargo until paper acceptance) ──────────────
# figures, benchmark outputs, supplementary — released on acceptance
results/figures/
results/benchmark/
results/validation/
results/supplementary/
results/top15_candidates_raw.csv
results/top15_bioprospecting_report.csv
top15_bioprospecting_report.csv

# ── LOGS ──────────────────────────────────────────────────────────────
*.log
logs/

# ── WHAT IS TRACKED (public) ─────────────────────────────────────────
# src/pipeline/   — all scripts
# src/utils/      — helper scripts
# src/report.py   — executive summary generator
# config/taxa_list_example.json
# examples/figures/     — selected paper figures (ROC, LOOO-CV, etc.)
# examples/dendrograms/ — dendrogram PNGs
# examples/benchmark/   — Fig4 composite
# README.md, .gitignore, requirements.txt, LICENSE, REPORT.md